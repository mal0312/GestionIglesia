# GitHub Pages project path for this repository.
VITE_BASE_PATH=/GestionIglesia/

# Google OAuth allowlist for the private panel.
VITE_GOOGLE_CLIENT_ID=000000000000-example.apps.googleusercontent.com
VITE_AUTHORIZED_EDITOR_EMAILS=editora@example.com
VITE_AUTHORIZED_ADMIN_EMAILS=admin@example.com

# Public forms send contact and Donacion de mercaderia to this Apps Script.
VITE_GOOGLE_APPS_SCRIPT_EMAIL_ENDPOINT=https://script.google.com/macros/s/example/exec

# Firestore content storage. Messaging sender id is optional for this app but
# usually present in the Firebase web app configuration.
VITE_FIREBASE_API_KEY=example-api-key
VITE_FIREBASE_PROJECT_ID=example-project-id
VITE_FIREBASE_APP_ID=1:000000000000:web:example
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
